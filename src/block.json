{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "imagesnippets/gallery",
	"version": "0.1.0",
	"title": "ImageSnippets Gallery",
	"category": "media",
	"icon": "format-gallery",
	"description": "Responsive, server-rendered gallery of images from ImageSnippets, with embedded provenance metadata (JSON-LD).",
	"keywords": [ "gallery", "imagesnippets", "rdf", "provenance", "sparql", "media" ],
	"textdomain": "image-snippets-gallery",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"gallery": { "type": "string", "default": "" },
		"userId": { "type": "string", "default": "" },
		"endpoint": { "type": "string", "default": "" },
		"displayCaption": { "type": "boolean", "default": false },
		"displayTitle": { "type": "boolean", "default": false },
		"layout": { "type": "string", "default": "grid" },
		"order": { "type": "string", "default": "asc" },
		"orderBy": { "type": "string", "default": "title" },
		"limit": { "type": "number", "default": 40 },
		"thumbSize": { "type": "string", "default": "medium" }
	},
	"example": {
		"attributes": {
			"gallery": "hs_gallery02",
			"displayCaption": true,
			"displayTitle": true,
			"limit": 6
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
